{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "crawlie",
  "version": "0.5.0",
  "identifier": "com.spronta.crawlie",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "crawlie",
        "width": 1280,
        "height": 860,
        "minWidth": 920,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 19 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/spronta/crawlie/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyOTYyRTkxQURDMDcwNzAKUldSd2NNQ3RrUzZXSWtDU2dvcHYyeG9QNFp4UHp1Nk9tZCtrVVVhTmJlRjlnQTJaVk83RHlIR0sK"
    }
  }
}
