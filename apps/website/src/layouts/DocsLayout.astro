---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/prose.css';
import type { MarkdownHeading } from 'astro';

interface NavItem { slug: string; title: string; section: string; order: number; }

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  nav: NavItem[];
  headings: MarkdownHeading[];
}

const { title, description, currentSlug, nav, headings } = Astro.props;

// group nav by section, preserving first-seen order
const sections: { name: string; items: NavItem[] }[] = [];
for (const item of [...nav].sort((a, b) => a.order - b.order)) {
  let s = sections.find((x) => x.name === item.section);
  if (!s) { s = { name: item.section, items: [] }; sections.push(s); }
  s.items.push(item);
}

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={`${title} · crawlie — SEO & GEO crawler docs`} description={description} canonical={`/docs/${currentSlug}`}>
  <SiteHeader />
  <div class="docs container">
    <aside class="sidebar">
      <nav>
        <a class="sidebar-download" href="https://github.com/spronta/crawlie/releases/latest" data-track="cta_download" data-track-location="docs-sidebar">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="currentColor">
            <path d="M8 1.5a.75.75 0 0 1 .75.75v6.69l2.22-2.22a.75.75 0 1 1 1.06 1.06l-3.5 3.5a.75.75 0 0 1-1.06 0l-3.5-3.5a.75.75 0 0 1 1.06-1.06l2.22 2.22V2.25A.75.75 0 0 1 8 1.5ZM2.75 12.5a.75.75 0 0 1 .75.75v.25h9v-.25a.75.75 0 0 1 1.5 0v.5A1.25 1.25 0 0 1 12.75 15h-9.5A1.25 1.25 0 0 1 2 13.75v-.5a.75.75 0 0 1 .75-.75Z"/>
          </svg>
          Download for macOS
        </a>
        {sections.map((s) => (
          <div class="group">
            <p class="group-title">{s.name}</p>
            <ul>
              {s.items.map((item) => (
                <li>
                  <a href={`/docs/${item.slug}`} class={item.slug === currentSlug ? 'active' : ''}>
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <article class="content">
      <p class="eyebrow">Docs</p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <div class="prose">
        <slot />
      </div>
    </article>

    <aside class="toc">
      {toc.length > 0 && (
        <div class="toc-inner">
          <p class="toc-title">On this page</p>
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'sub' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>
  <SiteFooter />
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) 200px;
    gap: 40px;
    align-items: start;
    padding-top: 40px;
    padding-bottom: 80px;
  }
  .sidebar, .toc { position: sticky; top: 84px; }
  .sidebar nav { font-size: 14px; }
  .sidebar-download {
    display: flex; align-items: center; justify-content: center; gap: 7px;
    margin-bottom: 22px; padding: 9px 12px;
    font-size: 13.5px; font-weight: 600;
    color: var(--bg); border-radius: 7px;
    border: 1px solid transparent;
    background: var(--text);
    box-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
    transition: background 0.15s ease, transform 0.05s ease;
  }
  .sidebar-download:hover {
    text-decoration: none;
    color: var(--bg);
    background: color-mix(in srgb, var(--text) 86%, var(--bg));
  }
  .sidebar-download:active { transform: translateY(1px); }
  .group { margin-bottom: 22px; }
  .group-title {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--muted-2); margin: 0 0 8px;
  }
  .sidebar ul, .toc ul { list-style: none; margin: 0; padding: 0; }
  .sidebar li a {
    display: block; padding: 5px 10px; margin: 1px 0;
    color: var(--muted); border-radius: 6px; border-left: 2px solid transparent;
  }
  .sidebar li a:hover { color: var(--text); background: var(--panel); text-decoration: none; }
  .sidebar li a.active {
    color: var(--link); background: color-mix(in srgb, var(--link) 10%, transparent);
    border-left-color: var(--link);
  }

  .content { min-width: 0; }
  .content > h1 { font-size: clamp(28px, 4vw, 38px); margin: 4px 0 12px; }
  .content > .lede { color: var(--muted); font-size: 18px; margin: 0 0 32px; }

  .toc-inner { font-size: 13px; }
  .toc-title {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--muted-2); margin: 0 0 8px;
  }
  .toc li a { display: block; padding: 4px 0; color: var(--muted); }
  .toc li.sub a { padding-left: 12px; font-size: 12.5px; }
  .toc li a:hover { color: var(--text); text-decoration: none; }

  @media (max-width: 1080px) {
    .docs { grid-template-columns: 200px minmax(0, 1fr); }
    .toc { display: none; }
  }
  @media (max-width: 760px) {
    .docs { grid-template-columns: 1fr; }
    .sidebar {
      position: static; border-bottom: 1px solid var(--border-soft);
      padding-bottom: 16px; margin-bottom: 8px;
    }
  }
</style>

<style>
  /* prose (markdown) styles are shared with the changelog — see prose.css,
     imported in the frontmatter above. */
</style>
