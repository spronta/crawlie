---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { COMPETITORS } from "../../data/compare";
import { AUTHOR, authorLd } from "../../data/author";

export function getStaticPaths() {
  return COMPETITORS.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props;
const SITE = "https://crawlie.dev";
const url = `${SITE}/compare/${c.slug}`;

// GEO: structured data so AI search can parse the comparison and the Q&A.
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: c.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE },
    { "@type": "ListItem", position: 2, name: "Compare", item: `${SITE}/compare` },
    { "@type": "ListItem", position: 3, name: `crawlie vs ${c.name}`, item: url },
  ],
};
const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `crawlie vs ${c.name}`,
  description: c.description,
  datePublished: c.updated,
  dateModified: c.updated,
  author: authorLd(),
  publisher: { "@type": "Organization", name: "Spronta Ltd", url: SITE },
  mainEntityOfPage: url,
};

function cellClass(win: string, side: "crawlie" | "them") {
  if (win === "tie") return "tie";
  return win === side ? "yes" : "no";
}
const updatedLabel = new Date(c.updated).toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const others = COMPETITORS.filter((x) => x.slug !== c.slug);
---

<BaseLayout title={`${c.title}`} description={c.description} canonical={`/compare/${c.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />

  <SiteHeader />

  <main class="cmp container">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>/</span> <a href="/compare">Compare</a> <span>/</span>
      <span aria-current="page">crawlie vs {c.name}</span>
    </nav>

    <article>
      <header class="cmp-head">
        <p class="eyebrow">crawlie vs {c.name}</p>
        <h1>The free, open-source {c.name} alternative</h1>
        <p class="tagline">{c.tagline}</p>
        <p class="byline">By <a href={AUTHOR.url} target="_blank" rel="noopener author">{AUTHOR.name}</a> · Updated {updatedLabel}</p>
      </header>

      <!-- Answer-first summary: the citable TL;DR. -->
      <section class="tldr" aria-label="Summary">
        <h2 class="sr-h">In short</h2>
        <p>{c.answer}</p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/docs/getting-started" data-track="cta_get_started" data-track-location="compare">Get started — it's free</a>
          <a class="btn btn-ghost" href="https://github.com/spronta/crawlie" target="_blank" rel="noopener" data-track="cta_github" data-track-location="compare">View on GitHub</a>
        </div>
      </section>

      <section aria-labelledby="at-a-glance">
        <h2 id="at-a-glance">crawlie vs {c.name} at a glance</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Feature</th><th class="us">crawlie</th><th>{c.name}</th></tr>
            </thead>
            <tbody>
              {c.rows.map((row) => (
                <tr>
                  <td class="label">{row.feature}</td>
                  <td class={`us ${cellClass(row.win, "crawlie")}`}>{row.crawlie}</td>
                  <td class={cellClass(row.win, "them")}>{row.them}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {c.reasons.map((r) => (
        <section>
          <h2>{r.h}</h2>
          <p>{r.p}</p>
        </section>
      ))}

      <section>
        <h2>Where {c.name} is still the better choice</h2>
        <p>No tool wins on everything — here's where {c.name} currently leads, so you can choose with eyes open:</p>
        <ul class="honest">
          {c.strengths.map((s) => <li>{s}</li>)}
        </ul>
      </section>

      <section aria-labelledby="faq">
        <h2 id="faq">Frequently asked questions</h2>
        <dl class="faq">
          {c.faq.map((f) => (
            <div class="qa">
              <dt>{f.q}</dt>
              <dd>{f.a}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="closing">
        <h2>Try crawlie on your own site</h2>
        <p>Free, open-source, and installable in seconds. Crawl any number of URLs, get plain-English fixes, and check your AI-search readiness.</p>
        <div class="cmd"><code>npm i -g crawlie &amp;&amp; crawlie crawl https://your-site.com</code></div>
        <div class="cta-row">
          <a class="btn btn-primary" href="/docs/getting-started" data-track="cta_get_started" data-track-location="compare-footer">Read the docs</a>
          <a class="btn btn-ghost" href="https://github.com/spronta/crawlie/releases/latest" data-track="cta_download" data-track-location="compare-footer">Download the desktop app</a>
        </div>
        {others.length > 0 && (
          <p class="more">
            Also compare:
            {others.map((o, i) => (
              <>{i > 0 ? ", " : " "}<a href={`/compare/${o.slug}`}>crawlie vs {o.name}</a></>
            ))}
          </p>
        )}
      </section>

      <AuthorBio />
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .cmp { padding-top: 28px; padding-bottom: 72px; max-width: 820px; }
  .crumbs { font-size: 13px; color: var(--muted-2); margin-bottom: 20px; }
  .crumbs a { color: var(--muted); }
  .crumbs span { margin: 0 4px; }

  .cmp-head h1 { font-size: clamp(28px, 4.4vw, 40px); margin: 6px 0 10px; }
  .tagline { color: var(--muted); font-size: 18px; margin: 0 0 8px; max-width: 56ch; }
  .byline { font-family: var(--font-mono); font-size: 12.5px; color: var(--muted-2); margin: 0; }

  .tldr {
    margin: 28px 0 8px; padding: 20px 22px;
    background: var(--panel); border: 1px solid var(--border-soft); border-radius: var(--radius);
  }
  .tldr p { margin: 0 0 16px; font-size: 16.5px; line-height: 1.6; color: #d6dde7; }
  .sr-h { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; }

  .cmp section { margin-top: 40px; }
  /* Neutralise the global `section { padding: 72px 0 }` that otherwise stacks
     huge gaps between sections here (the TL;DR box keeps its own padding). */
  .cmp section:not(.tldr) { padding: 0; }
  .cmp section > h2 {
    font-size: 23px; margin: 0 0 12px; padding-top: 18px;
    border-top: 1px solid var(--border-soft); color: var(--text);
  }
  .tldr h2 { border: 0; padding: 0; }
  .cmp section > p { color: #d2d9e4; font-size: 16px; line-height: 1.65; margin: 0 0 12px; max-width: 70ch; }

  .table-wrap { overflow-x: auto; border: 1px solid var(--border-soft); border-radius: var(--radius); }
  table { width: 100%; border-collapse: collapse; font-size: 14.5px; min-width: 480px; }
  th, td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border-soft); }
  thead th { color: var(--muted); font-weight: 500; font-size: 13px; }
  thead th.us { color: var(--link); font-weight: 700; }
  tbody tr:last-child td { border-bottom: 0; }
  td.label { color: var(--text); font-weight: 500; }
  td.us { background: rgba(59, 158, 255, 0.06); }
  td.yes { color: var(--green); }
  td.no { color: var(--muted-2); }
  td.tie { color: var(--text); }

  ul.honest { margin: 0; padding-left: 20px; }
  ul.honest li { color: #d2d9e4; font-size: 16px; line-height: 1.6; margin: 8px 0; max-width: 70ch; }

  .faq { margin: 0; }
  .faq .qa { padding: 16px 0; border-bottom: 1px solid var(--border-soft); }
  .faq .qa:last-child { border-bottom: 0; }
  .faq dt { font-weight: 600; color: var(--text); font-size: 16px; margin-bottom: 6px; }
  .faq dd { margin: 0; color: var(--muted); font-size: 15.5px; line-height: 1.6; max-width: 70ch; }

  .closing .cmd {
    font-family: var(--font-mono); font-size: 13.5px;
    background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 12px 16px; margin: 0 0 16px; overflow-x: auto;
  }
  .closing .cmd code { color: var(--text); white-space: nowrap; }
  .more { font-size: 14.5px; color: var(--muted); }
</style>
