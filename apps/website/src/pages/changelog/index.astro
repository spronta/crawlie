---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import '../../styles/prose.css';

// Sort by semantic version, newest first — dates collide when we ship more than
// once a day, so version is the source of truth for ordering.
const vkey = (v: string) => v.split('.').map((n) => parseInt(n, 10) || 0);
const entries = (await getCollection('changelog')).sort((a, b) => {
  const x = vkey(a.data.version);
  const y = vkey(b.data.version);
  return y[0] - x[0] || y[1] - x[1] || y[2] - x[2];
});
const rendered = await Promise.all(
  entries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content }))
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Changelog · Crawlie SEO & GEO crawler"
  description="Every notable change to Crawlie: new checks, MCP improvements, custom extraction, and more, newest first. Subscribe to the biweekly digest."
  canonical="/changelog"
>
  <SiteHeader />

  <main class="container changelog">
    <header class="cl-head">
      <p class="eyebrow">Changelog</p>
      <h1>What's new in Crawlie</h1>
      <p class="lede">We ship suspiciously often. If we were a legacy SEO audit tool, we'd be a little concerned.</p>
    </header>

    <div class="cl-list">
      {rendered.map((e) => {
        const Content = e.Content;
        return (
          <article class="cl-item" id={`v${e.data.version}`}>
            <div class="cl-meta">
              <a class="cl-ver" href={`/changelog/${e.data.version}`}>v{e.data.version}</a>
              <time datetime={e.data.date.toISOString()}>{fmt(e.data.date)}</time>
              <a class="cl-permalink" href={`/changelog/${e.data.version}`} aria-label={`Permalink to v${e.data.version}`}>#</a>
            </div>
            <div class="cl-body prose">
              <Content />
            </div>
          </article>
        );
      })}
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  /* Only set vertical padding so the container's horizontal padding survives
     (a `padding` shorthand here would zero it and flush content to the edges
     on mobile). */
  .changelog {
    padding-block: 56px 96px;
  }
  .cl-head {
    max-width: 720px;
    margin: 0 auto 8px;
    text-align: center;
  }
  .cl-head h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-feature-settings: 'calt' 1;
    font-size: clamp(30px, 5vw, 42px);
    letter-spacing: -0.01em;
    margin: 6px 0 10px;
    color: var(--heading);
  }
  .cl-head .lede {
    color: var(--muted);
    font-size: 17px;
    margin: 0;
  }

  /* Centred as a block; the entries inside stay left-aligned. */
  .cl-list {
    max-width: 860px;
    margin: 48px auto 0;
  }
  .cl-item {
    display: grid;
    grid-template-columns: 150px minmax(0, 1fr);
    gap: 36px;
    padding: 36px 0;
    border-top: 1px solid var(--border-soft);
    scroll-margin-top: 84px;
  }
  .cl-meta {
    position: sticky;
    top: 84px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cl-ver {
    display: inline-flex;
    align-items: center;
    align-self: start;
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--panel);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .cl-ver:hover {
    text-decoration: none;
    color: var(--link);
    border-color: color-mix(in srgb, var(--link) 50%, transparent);
  }
  .cl-meta time {
    color: var(--muted-2);
    font-size: 13.5px;
    font-variant-numeric: tabular-nums;
    padding-left: 2px;
  }
  .cl-permalink {
    font-family: var(--font-mono);
    color: var(--muted-2);
    font-size: 14px;
    opacity: 0;
    transition: opacity 0.15s ease;
    padding-left: 2px;
  }
  .cl-item:hover .cl-permalink {
    opacity: 1;
  }
  .cl-permalink:hover {
    color: var(--link);
    text-decoration: none;
  }

  /* Tighten the rendered prose inside a changelog card. */
  .cl-body :global(p:first-child) {
    margin-top: 0;
    font-size: 17px;
    color: var(--text);
  }
  .cl-body :global(h3) {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted-2);
    border: 0;
    padding: 0;
    margin: 22px 0 10px;
  }

  @media (max-width: 680px) {
    .cl-item {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .cl-meta {
      position: static;
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }
    .cl-permalink {
      display: none;
    }
  }
</style>
