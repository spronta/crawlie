---
// Email subscribe form. Posts JSON to the /api/subscribe serverless function,
// which adds the contact to a Resend audience. Enhanced inline; shows feedback.
---
<form class="subscribe">
  <input
    type="email"
    name="email"
    required
    placeholder="you@example.com"
    aria-label="Email address"
    autocomplete="email"
  />
  <button type="submit" class="subscribe-btn">Subscribe</button>
  <p class="subscribe-msg" data-msg role="status" aria-live="polite"></p>
  <p class="subscribe-consent">
    By subscribing, you agree to receive Crawlie emails and confirm you have read our
    <a href="/legal/privacy">Privacy Policy</a>. Unsubscribe anytime.
  </p>
</form>

<script is:inline>
  // Bind every subscribe form on the page. Idempotent: the :not([data-bound])
  // filter means this is safe even when the component renders more than once
  // (e.g. the changelog panel + the footer), each emitting this inline script.
  (() => {
    document.querySelectorAll('form.subscribe:not([data-bound])').forEach((form) => {
      form.dataset.bound = 'true';
      const msg = form.querySelector('[data-msg]');
      const btn = form.querySelector('button');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = new FormData(form).get('email');
        btn.disabled = true;
        msg.textContent = '';
        delete msg.dataset.ok;
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok) {
            form.reset();
            msg.dataset.ok = 'true';
            msg.textContent = "You're subscribed. Look out for the biweekly digest.";
          } else {
            msg.dataset.ok = 'false';
            msg.textContent = data.error || 'Something went wrong. Please try again.';
          }
        } catch {
          msg.dataset.ok = 'false';
          msg.textContent = 'Network error. Please try again.';
        } finally {
          btn.disabled = false;
        }
      });
    });
  })();
</script>

<style>
  .subscribe {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 0;
  }
  .subscribe input {
    flex: 1;
    min-width: 200px;
    padding: 11px 14px;
    border: 1px solid var(--border-soft);
    border-right: 0;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    background: var(--bg);
    color: var(--text);
    font-size: 14.5px;
  }
  .subscribe input:focus {
    outline: none;
    border-color: var(--blue);
  }
  /* Inline, borderless button joined to the input: white fill, blue label. */
  .subscribe-btn {
    flex: 0 0 auto;
    border: 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 0 20px;
    background: #fff;
    color: #0a0d14;
    font-family: inherit;
    font-size: 14.5px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .subscribe-btn:hover {
    background: color-mix(in srgb, #000 7%, #fff);
  }
  .subscribe-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .subscribe-msg {
    width: 100%;
    margin: 0;
    font-size: 13.5px;
    color: var(--muted);
  }
  .subscribe-msg:not(:empty) {
    margin: 8px 0 0;
  }
  .subscribe-msg[data-ok='true'] {
    color: var(--green);
  }
  .subscribe-msg[data-ok='false'] {
    color: var(--red);
  }
  .subscribe-consent {
    width: 100%;
    margin: 8px 0 0;
    font-size: 12px;
    line-height: 1.5;
    color: var(--muted-2);
  }
  .subscribe-consent a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .subscribe-consent a:hover {
    color: var(--text);
  }
</style>
