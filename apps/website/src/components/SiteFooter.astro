---
import BrandLockup from './BrandLockup.astro';
const GITHUB = 'https://github.com/spronta/crawlie';
const year = 2026;
---
<footer class="site-footer">
  <div class="container cols">
    <div class="about">
      <a href="/" class="brand" aria-label="crawlie home"><BrandLockup height={30} /></a>
      <p>The free, open-source technical-SEO &amp; GEO crawler — built for humans and agents.</p>
    </div>
    <div class="group">
      <h4>Product</h4>
      <a href="/#features">Features</a>
      <a href="/#agents">Agents &amp; MCP</a>
      <a href="/compare">Compare</a>
      <a href="/docs/checks">What it checks</a>
    </div>
    <div class="group">
      <h4>Docs</h4>
      <a href="/docs/getting-started">Getting started</a>
      <a href="/docs/cli">CLI</a>
      <a href="/docs/mcp">MCP server</a>
      <a href="/docs/skills-and-plugin">Skills &amp; plugin</a>
      <a href="/changelog">Changelog</a>
    </div>
    <div class="group">
      <h4>Project</h4>
      <a href={GITHUB} target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.npmjs.com/package/crawlie" target="_blank" rel="noopener">npm</a>
      <a href={`${GITHUB}/releases`} target="_blank" rel="noopener">Releases</a>
      <a href="https://linkedin.com/in/sean-exe" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
  <div class="container baseline">
    <span>© {year} Spronta Ltd</span>
    <span>Built fast. Audited with crawlie.</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-soft);
    padding: 84px 0 52px;
  }
  .cols {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .brand {
    display: inline-flex; align-items: center;
    color: var(--text);
  }
  .brand:hover { text-decoration: none; opacity: 0.85; }
  .about p {
    color: var(--muted); font-size: 16.5px; line-height: 1.6;
    max-width: 34ch; margin: 22px 0 0;
  }
  .group h4 {
    font-size: 14.5px; color: var(--text); font-weight: 600;
    letter-spacing: -0.01em; margin-bottom: 16px;
  }
  .group a {
    display: block; color: var(--muted); font-size: 15.5px;
    padding: 6px 0; transition: color 0.15s ease;
  }
  .group a:hover { color: var(--text); text-decoration: none; }
  .baseline {
    display: flex; justify-content: space-between;
    margin-top: 64px; padding-top: 28px;
    border-top: 1px solid var(--border-soft);
    color: var(--muted-2); font-size: 13.5px;
    font-family: var(--font-mono);
  }
  @media (max-width: 760px) {
    .site-footer { padding: 56px 0 40px; }
    .cols { grid-template-columns: 1fr 1fr; gap: 36px; }
    .about { grid-column: 1 / -1; }
    .baseline { flex-direction: column; gap: 6px; margin-top: 44px; }
  }
</style>
