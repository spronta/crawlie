---
import BrandLockup from './BrandLockup.astro';
import SubscribeForm from './SubscribeForm.astro';
const GITHUB = 'https://github.com/spronta/crawlie';
const year = 2026;
---
<footer class="site-footer">
  <div class="container foot-subscribe">
    <div class="foot-subscribe-copy">
      <p class="eyebrow">Newsletter</p>
      <h3>Crawl smarter, every two weeks</h3>
      <p>Stay up to date on new checks, MCP improvements, and fixes, rounded up every couple of weeks. No spam, unsubscribe anytime.</p>
    </div>
    <div class="foot-subscribe-form">
      <SubscribeForm />
    </div>
  </div>

  <div class="container cols">
    <div class="about">
      <a href="/" class="brand" aria-label="crawlie home"><BrandLockup height={30} /></a>
      <p>The free, open-source technical-SEO &amp; GEO crawler — built for humans and agents.</p>
    </div>
    <div class="group">
      <h4>Product</h4>
      <a href="/#features">Features</a>
      <a href="/#agents">Agents &amp; MCP</a>
      <a href="/compare">Compare</a>
      <a href="/docs/checks">What it checks</a>
    </div>
    <div class="group">
      <h4>Docs</h4>
      <a href="/docs/getting-started">Getting started</a>
      <a href="/docs/cli">CLI</a>
      <a href="/docs/mcp">MCP server</a>
      <a href="/docs/skills-and-plugin">Skills &amp; plugin</a>
      <a href="/changelog">Changelog</a>
    </div>
    <div class="group">
      <h4>Compare</h4>
      <a href="/compare">All comparisons</a>
      <a href="/compare/screaming-frog">vs Screaming Frog</a>
      <a href="/compare/sitebulb">vs Sitebulb</a>
    </div>
    <div class="group">
      <h4>Project</h4>
      <a href={GITHUB} target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.npmjs.com/package/crawlie" target="_blank" rel="noopener">npm</a>
      <a href={`${GITHUB}/releases`} target="_blank" rel="noopener">Releases</a>
      <a href="https://linkedin.com/in/sean-exe" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
  <div class="container baseline">
    <span>© {year} Spronta Ltd</span>
    <nav class="legal-links" aria-label="Legal">
      <a href="/legal/terms">Terms of Service</a>
      <a href="/legal/privacy">Privacy Policy</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    /* The full-bleed newsletter band is the first child and carries its own
       top border, so the footer sits flush against the page content above. */
    padding: 0 0 52px;
  }
  /* Full-bleed footer: span the whole viewport with comfortable edge gutters
     instead of the centred 1080px content column. */
  .site-footer .container {
    max-width: none;
    padding-inline: clamp(24px, 4vw, 56px);
  }
  .cols {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .brand {
    display: inline-flex; align-items: center;
    color: var(--text);
  }
  .brand:hover { text-decoration: none; opacity: 0.85; }
  .about p {
    color: var(--muted); font-size: 16.5px; line-height: 1.6;
    max-width: 34ch; margin: 22px 0 0;
  }
  /* Full-width standalone signup band above the link columns. Full-bleed panel
     tint (slightly lighter than the page) frames it as its own section. */
  .foot-subscribe {
    display: grid;
    grid-template-columns: 1fr minmax(0, 460px);
    align-items: center;
    gap: 24px 64px;
    padding-block: 44px;
    margin-bottom: 60px;
    background: var(--panel);
    border-block: 1px solid var(--border-soft);
  }
  .foot-subscribe-copy .eyebrow {
    margin: 0 0 12px;
    color: var(--baby-blue);
    font-family: var(--font-mono);
    font-size: 11.5px;
    line-height: 1;
  }
  .foot-subscribe-copy h3 {
    font-family: var(--font-display); font-weight: 500;
    font-feature-settings: 'calt' 1;
    font-size: clamp(24px, 3vw, 32px); letter-spacing: -0.01em;
    color: #fff; margin: 0 0 8px;
  }
  .foot-subscribe-copy p {
    color: var(--muted); font-size: 16px; line-height: 1.55;
    margin: 0; max-width: 52ch;
  }
  .foot-subscribe-form :global(.subscribe input) {
    padding: 13px 16px; font-size: 15px;
  }
  .foot-subscribe-form :global(.subscribe-btn) {
    padding: 0 24px; font-size: 15px;
  }
  .group h4 {
    font-size: 14.5px; color: var(--text); font-weight: 600;
    letter-spacing: -0.01em; margin-bottom: 16px;
  }
  .group a {
    display: block; color: var(--muted); font-size: 15.5px;
    padding: 6px 0; transition: color 0.15s ease;
  }
  .group a:hover { color: var(--text); text-decoration: none; }
  .baseline {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 64px; padding-top: 28px;
    border-top: 1px solid var(--border-soft);
    color: var(--muted-2); font-size: 13.5px;
    font-family: var(--font-mono);
  }
  .legal-links { display: flex; gap: 18px; }
  .legal-links a { color: var(--muted-2); transition: color 0.15s ease; }
  .legal-links a:hover { color: var(--text); text-decoration: none; }
  @media (max-width: 760px) {
    .site-footer { padding: 0 0 40px; }
    .foot-subscribe {
      grid-template-columns: 1fr; gap: 18px;
      padding-block: 32px; margin-bottom: 44px;
    }
    .cols { grid-template-columns: 1fr 1fr; gap: 36px; }
    .about { grid-column: 1 / -1; }
    .baseline { flex-direction: column; gap: 6px; margin-top: 44px; }
  }
</style>
