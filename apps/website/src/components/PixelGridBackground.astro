---
/* 8-bit ASCII field: chunky block glyphs (░▒▓█) on a coarse grid, a quantised
   blue palette, and low-fps stepped motion for a retro feel. A brighter "scan"
   wavefront sweeps diagonally across — the agent crawling the page. Decorative
   canvas behind a positioned parent; aria-hidden and static if reduced-motion. */
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---
<div class={`pixel-grid ${cls}`} aria-hidden="true">
  <canvas></canvas>
</div>

<style>
  .pixel-grid {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: radial-gradient(125% 92% at 50% 44%, transparent 12%, #000 70%);
    mask-image: radial-gradient(125% 92% at 50% 44%, transparent 12%, #000 70%);
  }
  .pixel-grid canvas {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }
</style>

<script>
  const roots = document.querySelectorAll<HTMLDivElement>('.pixel-grid');

  roots.forEach((el) => {
    const canvas = el.querySelector('canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const CELL = 20; // chunky cells
    const FPS = 12; // low frame-rate = retro stepping
    const BLOCKS = [' ', '░', '▒', '▓', '█'];
    // Quantised 8-bit blue ramp (deep → bright).
    const PALETTE = [
      [10, 38, 120],
      [0, 68, 200],
      [0, 85, 238],
      [59, 158, 255],
      [150, 200, 255],
    ];

    let cols = 0;
    let rows = 0;
    let dpr = 1;
    let last = 0;
    let raf = 0;

    function resize() {
      const r = el.getBoundingClientRect();
      if (r.width === 0 || r.height === 0) return;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.ceil(r.width * dpr);
      canvas.height = Math.ceil(r.height * dpr);
      cols = Math.ceil(r.width / CELL) + 1;
      rows = Math.ceil(r.height / CELL) + 1;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = `${CELL}px ui-monospace, "SF Mono", Menlo, monospace`;
      ctx.textBaseline = 'top';
    }

    function isLight(): boolean {
      const t = document.documentElement.dataset.theme;
      if (t === 'light') return true;
      if (t === 'dark') return false;
      return window.matchMedia('(prefers-color-scheme: light)').matches;
    }

    function draw(step: number) {
      const T = step * 0.07; // slow advance per retro step
      // Light boxes need a stronger blue so the texture reads (recomputed each
      // frame so it reacts to the theme toggle live).
      const aMul = isLight() ? 2.1 : 1;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      // Diagonal scan wavefront, wraps across the grid.
      const span = cols + rows;
      const scan = (T * 4) % (span + 30);

      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          let f =
            Math.sin(x * 0.55 + T) +
            Math.sin(y * 0.6 - T * 0.8) +
            Math.sin((x * 0.6 + y * 0.45) + T * 0.6); // diagonal term breaks columns
          let n = (f + 3) / 6; // 0..1

          // Agent scan pass — lift cells near the wavefront.
          const d = Math.abs(x + y - scan);
          if (d < 6) n += (1 - d / 6) * 0.32;

          let level = Math.round(Math.min(1, Math.max(0, n)) * (BLOCKS.length - 1));
          if (level <= 0) continue;

          const [r, g, b] = PALETTE[level];
          const alpha = Math.min(0.6, (0.05 + level * 0.05) * aMul);
          ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
          ctx.fillText(BLOCKS[level], x * CELL, y * CELL);
        }
      }
    }

    function loop(now: number) {
      raf = requestAnimationFrame(loop);
      if (now - last < 1000 / FPS) return;
      last = now;
      draw(Math.floor(now / (1000 / FPS)));
    }

    resize();
    if ('ResizeObserver' in window) {
      new ResizeObserver(() => {
        resize();
        if (reduce) draw(40);
      }).observe(el);
    } else {
      window.addEventListener('resize', () => {
        resize();
        if (reduce) draw(40);
      });
    }

    if (reduce) draw(40);
    else raf = requestAnimationFrame(loop);
  });
</script>
