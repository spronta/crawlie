---
interface Props {
  size?: number;
}
const { size = 26 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 32 32" fill="none" aria-hidden="true">
  <g stroke="var(--blue)" stroke-width="2" stroke-linecap="round">
    <path d="M16 16 L8 8" />
    <path d="M16 16 L24 9" />
    <path d="M16 16 L9 24" />
    <path d="M16 16 L24 23" />
  </g>
  <circle cx="16" cy="16" r="3.6" fill="var(--blue)" />
  <circle cx="8" cy="8" r="2.4" fill="var(--green)" />
  <circle cx="24" cy="9" r="2.4" fill="var(--amber)" />
  <circle cx="9" cy="24" r="2.4" fill="var(--text)" />
  <circle cx="24" cy="23" r="2.4" fill="var(--red)" />
</svg>
