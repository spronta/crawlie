---
// The crawlie icon mark. Monochrome and theme-aware: it inherits `currentColor`,
// so it's white on the dark site (and would flip on a light surface).
interface Props {
  size?: number;
}
const { size = 26 } = Astro.props;
const w = Math.round((size * 401) / 430);
---
<svg width={w} height={size} viewBox="0 0 401 430" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <path d="M174.795 364.538H304.606V430H0V125.791H174.795V364.538ZM401 304.209H226.205V65.4623H96.3943V0H401V304.209Z" fill="var(--blue)" />
</svg>
