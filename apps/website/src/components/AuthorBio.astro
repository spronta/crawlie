---
import { AUTHOR } from '../data/author';
---
<aside class="author-bio">
  <img class="ab-avatar" src={AUTHOR.image} alt={AUTHOR.name} width="52" height="52" loading="lazy" />
  <div class="ab-text">
    <p class="ab-name">
      {AUTHOR.name}
      <span class="ab-role">{AUTHOR.tagline}</span>
    </p>
    <p class="ab-bio">{AUTHOR.bio}</p>
    <div class="ab-links">
      <a class="ab-icon" href={AUTHOR.linkedin} target="_blank" rel="noopener author" aria-label={`${AUTHOR.name} on LinkedIn`}>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a class="ab-icon" href={AUTHOR.x} target="_blank" rel="noopener author" aria-label={`${AUTHOR.name} on X`}>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
          <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
        </svg>
      </a>
    </div>
  </div>
</aside>

<style>
  .author-bio {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
  }
  .ab-avatar {
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border-soft);
  }
  .ab-text { min-width: 0; }
  .ab-name {
    margin: 0 0 6px;
    font-weight: 600;
    color: var(--text);
    font-size: 15.5px;
  }
  .ab-role {
    display: block;
    font-weight: 400;
    color: var(--muted-2);
    font-size: 13px;
    margin-top: 2px;
  }
  .ab-bio {
    margin: 0 0 8px;
    color: var(--muted);
    font-size: 14.5px;
    line-height: 1.55;
    max-width: 62ch;
  }
  .ab-links {
    display: flex;
    gap: 8px;
  }
  .ab-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    color: var(--muted);
    border: 1px solid var(--border-soft);
    background: var(--panel);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .ab-icon:hover {
    color: var(--text);
    text-decoration: none;
    border-color: color-mix(in srgb, var(--baby-blue) 45%, transparent);
  }
</style>
