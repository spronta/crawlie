---
/* Animated blue ASCII field rendered to a canvas. Sits absolutely behind a
   positioned parent; purely decorative, so it's aria-hidden and non-interactive.
   Honors prefers-reduced-motion by drawing a single static frame. */
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---
<div class={`ascii-bg ${cls}`} aria-hidden="true">
  <canvas></canvas>
</div>

<style>
  .ascii-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    /* Keep the centre (where the copy lives) clear; fade the field in toward the edges. */
    -webkit-mask-image: radial-gradient(115% 85% at 50% 48%, transparent 14%, #000 68%);
    mask-image: radial-gradient(115% 85% at 50% 48%, transparent 14%, #000 68%);
  }
  .ascii-bg canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const fields = document.querySelectorAll<HTMLDivElement>('.ascii-bg');

  fields.forEach((el) => {
    const canvas = el.querySelector('canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Dark → bright glyph ramp.
    const RAMP = ' .,:;i1tfLCG08@';
    const CELL = 14; // px per glyph cell
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let cols = 0;
    let rows = 0;
    let dpr = 1;
    let last = 0;
    let raf = 0;

    function resize() {
      const r = el.getBoundingClientRect();
      if (r.width === 0 || r.height === 0) return;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.ceil(r.width * dpr);
      canvas.height = Math.ceil(r.height * dpr);
      cols = Math.ceil(r.width / CELL) + 1;
      rows = Math.ceil(r.height / CELL) + 1;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = `${CELL}px ui-monospace, "SF Mono", Menlo, monospace`;
      ctx.textBaseline = 'top';
    }

    function isLight(): boolean {
      const th = document.documentElement.dataset.theme;
      if (th === 'light') return true;
      if (th === 'dark') return false;
      return window.matchMedia('(prefers-color-scheme: light)').matches;
    }

    function draw(t: number) {
      const time = t * 0.0006;
      const aMul = isLight() ? 1.5 : 1;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          // Overlapping sine waves → a slow, flowing field value.
          const v =
            Math.sin(x * 0.18 + time * 1.3) +
            Math.cos(y * 0.22 - time) +
            Math.sin((x + y) * 0.12 + time * 0.6);
          const n = (v + 3) / 6; // normalise to ~0..1
          if (n < 0.18) continue;
          const ci = Math.min(RAMP.length - 1, Math.floor(n * RAMP.length));
          const ch = RAMP[ci];
          if (ch === ' ') continue;
          const alpha = Math.min(0.7, (0.05 + n * 0.4) * aMul);
          // Opulent blue, lifting toward sky-blue at the peaks.
          const g = 70 + Math.floor(n * 100);
          const b = 235 + Math.floor(n * 20);
          ctx.fillStyle = `rgba(${Math.floor(n * 30)}, ${g}, ${Math.min(255, b)}, ${alpha})`;
          ctx.fillText(ch, x * CELL, y * CELL);
        }
      }
    }

    function loop(t: number) {
      raf = requestAnimationFrame(loop);
      if (t - last < 1000 / 30) return; // cap ~30fps
      last = t;
      draw(t);
    }

    resize();
    if ('ResizeObserver' in window) {
      new ResizeObserver(() => {
        resize();
        if (reduce) draw(0);
      }).observe(el);
    } else {
      window.addEventListener('resize', () => {
        resize();
        if (reduce) draw(0);
      });
    }

    if (reduce) draw(0);
    else raf = requestAnimationFrame(loop);
  });
</script>
